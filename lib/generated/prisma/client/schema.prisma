generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  CategoryID   Int      @id @default(autoincrement())
  CategoryName String   @db.VarChar(250)
  LogoPath     String?  @db.VarChar(250)
  IsExpense    Boolean
  IsIncome     Boolean
  IsActive     Boolean
  Description  String?  @db.VarChar(500)
  UserID       Int
  Created      DateTime
  Modified     DateTime
  Sequence     Decimal? @db.Decimal(10, 2)
}

model expenses {
  ExpenseID      Int      @id @default(autoincrement())
  ExpenseDate    DateTime
  CategoryID     Int?
  SubCategoryID  Int?
  PeopleID       Int
  ProjectID      Int?
  Amount         Decimal  @db.Decimal(10, 2)
  ExpenseDetail  String?  @db.VarChar(500)
  AttachmentPath String?  @db.VarChar(250)
  Description    String?  @db.VarChar(500)
  UserID         Int
  Created        DateTime
  Modified       DateTime
}

model incomes {
  IncomeID       Int      @id @default(autoincrement())
  IncomeDate     DateTime
  CategoryID     Int?
  SubCategoryID  Int?
  PeopleID       Int
  ProjectID      Int?
  Amount         Decimal  @db.Decimal(10, 2)
  IncomeDetail   String?  @db.VarChar(500)
  AttachmentPath String?  @db.VarChar(250)
  Description    String?  @db.VarChar(500)
  UserID         Int
  Created        DateTime
  Modified       DateTime
}

model peoples {
  PeopleID    Int        @id @default(autoincrement())
  PeopleCode  String?    @db.VarChar(50)
  Password    String     @db.VarChar(255)
  PeopleName  String     @db.VarChar(250)
  Email       String     @db.VarChar(150)
  MobileNo    String     @db.VarChar(50)
  Description String?    @db.VarChar(500)
  UserID      Int
  Created     DateTime
  Modified    DateTime
  IsActive    Boolean?
  projects    projects[] @relation("ProjectAssignments")
}

model projects {
  ProjectID        Int       @id @default(autoincrement())
  ProjectName      String    @db.VarChar(250)
  ProjectLogo      String?   @db.VarChar(250)
  ProjectStartDate DateTime?
  ProjectEndDate   DateTime?
  ProjectDetail    String?   @db.VarChar(500)
  Description      String?   @db.VarChar(500)
  UserID           Int
  Created          DateTime
  Modified         DateTime
  IsActive         Boolean?
  assignedPeoples  peoples[] @relation("ProjectAssignments")
}

model sub_categories {
  SubCategoryID   Int      @id @default(autoincrement())
  CategoryID      Int
  SubCategoryName String   @db.VarChar(250)
  LogoPath        String?  @db.VarChar(250)
  IsExpense       Boolean
  IsIncome        Boolean
  IsActive        Boolean
  Description     String?  @db.VarChar(500)
  UserID          Int
  Created         DateTime
  Modified        DateTime
  Sequence        Decimal? @db.Decimal(10, 2)
}

enum Role {
  ADMIN
  USER
}

model users {
  UserID       Int      @id @default(autoincrement())
  UserName     String   @db.VarChar(250)
  EmailAddress String   @unique @map("Email") @db.VarChar(500)
  Password     String   @db.VarChar(255)
  MobileNo     String   @db.VarChar(50)
  Role         Role     @default(USER)
  ProfileImage String?  @db.VarChar(500)
  IsActive     Boolean
  Created      DateTime
  Modified     DateTime
}
